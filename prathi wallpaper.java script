    { id: 1, category: 'nature', url: 'https://images.unsplash.com/photo-1470071459604-3b5ec3a7fe05?auto=format&fit=crop&w=800&q=80' },
    { id: 2, category: 'cars', url: 'https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?auto=format&fit=crop&w=800&q=80' },
    { id: 3, category: 'abstract', url: 'https://images.unsplash.com/photo-1541701494587-cb58502866ab?auto=format&fit=crop&w=800&q=80' },
    { id: 4, category: 'gaming', url: 'https://images.unsplash.com/photo-1542751371-adc38448a05e?auto=format&fit=crop&w=800&q=80' },
    { id: 5, category: 'anime', url: 'https://images.unsplash.com/photo-1578632738908-4521c59639f8?auto=format&fit=crop&w=800&q=80' },
    { id: 6, category: 'nature', url: 'https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&w=800&q=80' },
    // Add more items to test infinite scroll
];

const grid = document.getElementById('wallpaper-grid');
const modal = document.getElementById('preview-modal');
const modalImg = document.getElementById('modal-img');
const closeBtn = document.querySelector('.close-modal');
const pills = document.querySelectorAll('.pill');
const searchInput = document.getElementById('search-input');

// Initialize Gallery
function loadGallery(filter = 'all') {
    grid.innerHTML = '';
    const filtered = filter === 'all' 
        ? wallpaperData 
        : wallpaperData.filter(item => item.category === filter);

    filtered.forEach(item => {
        const card = document.createElement('div');
        card.className = 'card';
        card.innerHTML = `
            <img src="${item.url}" alt="${item.category}" loading="lazy">
            <div class="card-overlay">
                <div class="info">
                    <p>${item.category.toUpperCase()}</p>
                </div>
                <button class="fav-icon" onclick="toggleFavorite(${item.id})">
                    <i class="far fa-heart"></i>
                </button>
            </div>
        `;
        card.onclick = () => openModal(item.url);
        grid.appendChild(card);
    });
}

// Modal Logic
function openModal(url) {
    modal.style.display = 'flex';
    modalImg.src = url;
    document.body.style.overflow = 'hidden'; // Stop scroll
}

closeBtn.onclick = () => {
    modal.style.display = 'none';
    document.body.style.overflow = 'auto';
};

window.onclick = (event) => {
    if (event.target == modal) closeBtn.onclick();
};

// Filter Logic
pills.forEach(pill => {
    pill.onclick = () => {
        document.querySelector('.pill.active').classList.remove('active');
        pill.classList.add('active');
        loadGallery(pill.dataset.filter);
    };
});

// Search Logic
searchInput.oninput = (e) => {
    const term = e.target.value.toLowerCase();
    const cards = document.querySelectorAll('.card');
    cards.forEach(card => {
        const cat = card.querySelector('p').innerText.toLowerCase();
        card.style.display = cat.includes(term) ? 'block' : 'none';
    });
};

// Theme Toggle
const themeBtn = document.getElementById('theme-toggle');
themeBtn.onclick = () => {
    document.body.classList.toggle('light-theme');
    const icon = themeBtn.querySelector('i');
    icon.classList.toggle('fa-moon');
    icon.classList.toggle('fa-sun');
};

// LocalStorage Favorites (Simple Implementation)
function toggleFavorite(id) {
    event.stopPropagation();
    let favorites = JSON.parse(localStorage.getItem('favs')) || [];
    if(favorites.includes(id)) {
        favorites = favorites.filter(favId => favId !== id);
    } else {
        favorites.push(id);
    }
    localStorage.setItem('favs', JSON.stringify(favorites));
    alert('Updated Favorites!');
}

// Initial Load
window.onload = () => {
    loadGallery();
};
